{
  "name": "mocko",
  "private": true,
  "scripts": {
    "build": "npm run build --prefix ./mocko-proxy && npm run build --prefix ./mocko-control",
    "test": "npm test --prefix ./mocko-tests",
    "test:fast": "npm run test:fast --prefix ./mocko-tests",
    "prestart": "npm run build",
    "start:fast": "node ./mocko-cli/bin/main.js ./mocko-proxy/mocks --ui --watch",
    "start": "npm run start:fast"
  },
  "workspaces": [
    "mocko-control",
    "mocko-proxy",
    "mocko-cli",
    "mocko-tests"
  ]
}
