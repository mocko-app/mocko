{
  "name": "@mocko/tests",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "pretest": "npm run build --prefix ../mocko-proxy",
    "test": "jest --runInBand",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src",
    "format:check": "prettier --check src"
  },
  "devDependencies": {
    "@mocko/cli": "*",
    "@typescript-eslint/eslint-plugin": "^5.0.0",
    "@typescript-eslint/parser": "^5.0.0",
    "@types/jest": "^28.1.8",
    "@types/node": "^16.0.0",
    "axios": "^0.27.2",
    "eslint": "^8.0.1",
    "eslint-config-prettier": "^8.3.0",
    "jest": "^28.0.0",
    "prettier": "^2.3.2",
    "ts-jest": "^28.0.8",
    "typescript": "^4.8.2"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.ts"],
    "testTimeout": 15000
  }
}
