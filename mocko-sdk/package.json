{
  "name": "@mocko/sdk",
  "version": "0.0.1-alpha.0",
  "description": "TypeScript SDK for integrating Mocko into test automations.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "npm run build && node --test tests/*.test.js tests/**/*.test.js",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src tests",
    "format:check": "prettier --check src tests",
    "prepack": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mocko-app/mocko.git"
  },
  "author": "Gabriel Pinheiro <gabrielctpinheiro@gmail.com>",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/mocko-app/mocko/issues"
  },
  "homepage": "https://github.com/mocko-app/mocko#readme",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^8.3.0",
    "eslint-plugin-prettier": "^4.2.5",
    "prettier": "^2.3.2",
    "typescript": "^5.9.2"
  },
  "publishConfig": {
    "access": "public",
    "tag": "alpha"
  }
}
