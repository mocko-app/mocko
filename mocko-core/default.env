SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_ALLOW-CORS=true

# URL of your actual API which will be proxied by mocko, leave it blank for non-proxied mode
PROXY_BASE-URI=
PROXY_TIMEOUT-MILLIS=60000

# Enables the internal deploy endpoint used by the UI flow. Disabled by default.
DEPLOY_ENDPOINT_ENABLED=false
# Controls Authorization: Bearer <token> for /__mocko__/ routes.
# none = open, deploy = protect deploy/mocks/hosts, all = protect deploy/flags/mocks/hosts.
MANAGEMENT_AUTH_MODE=deploy
# Shared secret used when MANAGEMENT_AUTH_MODE protects a route.
# DEPLOY_SECRET=

# Set REDIS_ENABLED to false to use mocks from the mock dir. Set it to true to fetch them from redis and
# auto update (requires mocko-api and mocko-ui).
REDIS_ENABLED=false
# Maximum number of entries returned by /__mocko__/flags listing before truncation.
FLAGS_LIST-LIMIT=200
# REDIS_URL=redis://:password@127.0.0.1:6379/0
# REDIS_PORT=6379
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=
# REDIS_DATABASE=0
# REDIS_PREFIX=mocko:
